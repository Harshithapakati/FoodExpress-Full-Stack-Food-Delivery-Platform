{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true,
    "serviceworker": true,
    "node": true
  },
  "globals": {
    "process": "readonly",
    "importScripts": "readonly",
    "clients": "readonly",
    "firebase": "readonly",
    "global": "readonly"
  },
  "extends": ["eslint:recommended", "plugin:react/recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["react"],
  "rules": {
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "indent": ["error", 2],
    "no-unused-vars": ["warn"],
    "no-empty": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/*.test.jsx", "src/setupTests.js"],
      "env": { "jest": true, "node": true }
    },
    {
      "files": ["public/firebase-messaging-sw.js"],
      "env": { "serviceworker": true },
      "globals": {
        "importScripts": "readonly",
        "firebase": "readonly",
        "clients": "readonly"
      }
    }
  ]
}
